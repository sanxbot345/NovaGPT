{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "User chat session containing chat messages",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "messages": { "type": "array" },
        "createdAt": { "type": "integer" }
      },
      "required": ["id", "title", "messages", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Metadata for the user account"
    },
    "users/{userId}/sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "The active chat sessions for the authenticated user"
    }
  }
}
